<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="TimeTracker.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TimeTracker"
    xmlns:converters="using:TimeTracker.Converters">
    
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="ms-appx:///Styles/TextStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:PageToStyleConverter x:Key="PageToStyleConverter"/>
            <converters:ZeroToCollapsedConverter x:Key="ZeroToCollapsedConverter"/>
            <converters:PeriodToStyleConverter x:Key="PeriodToStyleConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
