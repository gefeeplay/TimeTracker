<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TimeTracker.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:TimeTracker.ViewModels"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    Background="#F8FAFC">
 
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="White"
                Padding="40,20"
                BorderBrush="#E5E5E5"
                BorderThickness="0,0,0,1">

            <TextBlock Text="Обзор активности"
                      Style="{StaticResource PageHeaderTextStyle}"/>
        </Border>

        <!-- SCROLLABLE CONTENT -->
        <ScrollViewer Grid.Row="1">

            <StackPanel Margin="20"
                        Spacing="15">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>

                <!-- Карточки -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Всего сегодня -->
                    <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{Binding TotalTodayTitle}" Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text="{Binding TotalTodayTime}" Style="{StaticResource MetricLargeTextStyle}"/>
                            <TextBlock Text="{Binding TotalTodayDelta}" Style="{Binding DeltaTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Самое частое -->
                    <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding MostFrequentTitle}" Style="{StaticResource CaptionTextStyle}"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="24" Height="24" CornerRadius="8" Margin="0,0,10,0">
                                    <Image Width="24"
                                           Height="24"
                                           Source="{Binding MostFrequentIcon}" />
                                </Border>
                                <TextBlock Text="{Binding MostFrequentCategory}" 
                                           Style="{StaticResource MetricLargeTextStyle}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding MostFrequentDescription}" Style="{StaticResource CaptionTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- Смена окон -->
                    <Border Grid.Column="4" Background="White" CornerRadius="12" Padding="20">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding WindowSwitchesTitle}" Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text="{Binding WindowSwitchesCount}" Style="{StaticResource MetricLargeTextStyle}"/>
                            <TextBlock Text="{Binding WindowSwitchesDescription}" Style="{StaticResource CaptionTextStyle}"/>
                        </StackPanel>
                    </Border>

                </Grid>

                <!-- График -->
                <Border Background="White" CornerRadius="12" Padding="25" BorderBrush="#E5E5E5" BorderThickness="1">
                    <StackPanel Spacing="15">
                        <!-- Шапка графика -->
                        <Grid>
                            <TextBlock Text="{Binding WeekActivityTitle}"
                                       Style="{StaticResource SectionTitleTextStyle}"
                                       VerticalAlignment="Center"/>
                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="ToggleWeekChart_Click"
                                    Background="Transparent"
                                    BorderThickness="0">
                                <FontIcon FontSize="16" 
                                          Foreground="Black"
                                          Glyph="{Binding IsWeekChartVisible,  Converter={StaticResource BoolToGlyphConverter}}"/>
                            </Button>
                        </Grid>
                        <!-- График активности за неделю -->
                        <Grid x:Name="WeekChartContainer"
                                Height="300"
                                Opacity="1"
                                Visibility="{Binding IsWeekChartVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                RenderTransformOrigin="0.5,0">
                            
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="WeekChartScale" ScaleY="1"/>
                            </Grid.RenderTransform>
                            
                            <lvc:CartesianChart 
                                Height="300"
                                Background="Transparent"
                                Series="{Binding WeekActivitySeries}"
                                XAxes="{Binding WeekActivityXAxes}"
                                YAxes="{Binding WeekActivityYAxes}"
                                TooltipPosition="Top"
                                ZoomMode="None" />
                        </Grid>
                    </StackPanel>
                </Border>
                <!-- Нижние блоки -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Использованные приложения -->
                    <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" BorderBrush="#E5E5E5" BorderThickness="1">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Использованные приложения" Style="{StaticResource SectionTitleTextStyle}"/>
                            <ItemsControl ItemsSource="{Binding Applications}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:ApplicationUsage">
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0">
                                                <Image Width="32"
                                                       Height="32"
                                                       Source="{Binding IconPath}" />
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{x:Bind Name}" Style="{StaticResource AppTextStyle}"/>
                                                <TextBlock Text="{x:Bind Category}" Style="{StaticResource CaptionTextStyle}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                <TextBlock Text="{x:Bind TimeText}" Style="{StaticResource AppTextStyle}" HorizontalAlignment="Right"/>
                                                <!--<TextBlock Text="{x:Bind DeltaText}" FontSize="13" Foreground="#10B981" HorizontalAlignment="Right"/>-->
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="2"
                                Spacing="20">

                        <!-- Дневная цель -->
                        <Border Background="#A4C5EA" CornerRadius="12" Padding="20">
                            <StackPanel Spacing="10">
                                <TextBlock Text="{Binding DailyGoalTitle}" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="{Binding DailyGoalDescription}" FontSize="14" Foreground="White"/>
                                <TextBlock Text="{Binding DailyGoalPercent}" FontSize="18" Foreground="White" FontWeight="Bold"/>
                                <ProgressBar Minimum="0"
                                             Maximum="100"
                                             Value="{Binding DailyGoalPercentValue}"
                                             MinHeight="6"
                                             Background="#548AC5"
                                             Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <!-- Умные советы -->
                        <Border Background="White" CornerRadius="12" Padding="20" BorderBrush="#E5E5E5" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding TipsTitle}" Style="{StaticResource SectionTitleTextStyle}"/>
                                <Grid ColumnDefinitions="Auto, *">
                                    <Border Grid.Column="0"
                                            Width="32"
                                            Height="32"
                                            CornerRadius="8"
                                            Margin="0,0,10,0"
                                            Background="#F3F4F6"
                                            VerticalAlignment="Top">
                                        <FontIcon Glyph="&#xea1f;" FontSize="18" Foreground="#548AC5"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding TipsText}" 
                                               Style="{StaticResource CaptionTextStyle}" 
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        

                    </StackPanel>

                </Grid>

                <!-- График конкретного приложения за неделю -->
                <Border Background="White" CornerRadius="12" Padding="25" BorderBrush="#E5E5E5" BorderThickness="1">
                    <StackPanel Spacing="15">
                        <!-- Шапка графика -->
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                <TextBlock Text="Активность " Style="{StaticResource SectionTitleTextStyle}"/>
                                <ComboBox Width="180"
                                          MaxDropDownHeight="200"
                                          ItemsSource="{Binding TotalApplications}"
                                          SelectedItem="{Binding SelectedApplication, Mode=TwoWay}"
                                          Style="{StaticResource PrimaryComboBoxStyle}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Image Source="{Binding IconPath}" Width="16" Height="16"/>
                                                <TextBlock Text="{Binding AppName}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text=" (за неделю)" Style="{StaticResource SectionTitleTextStyle}"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="ToggleAppChart_Click"
                                    Background="Transparent"
                                    BorderThickness="0">
                                <FontIcon FontSize="16" 
                                          Foreground="Black"
                                          Glyph="{Binding IsAppChartVisible,  Converter={StaticResource BoolToGlyphConverter}}"/>
                            </Button>
                        </Grid>
                        <Grid x:Name="AppChartContainer"
                                Height="300"
                                Opacity="1"
                                Visibility="{Binding IsWeekChartVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                RenderTransformOrigin="0.5,0">

                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="AppChartScale" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <lvc:CartesianChart 
                                Height="300"
                                Background="Transparent"
                                Series="{Binding AppWeekActivitySeries}"
                                XAxes="{Binding AppWeekActivityXAxes}"
                                YAxes="{Binding AppWeekActivityYAxes}"
                                TooltipPosition="Top"
                                ZoomMode="None" />
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>

        </ScrollViewer>

    </Grid>
</Page>