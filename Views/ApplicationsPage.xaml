<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TimeTracker.Views.ApplicationsPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TimeTracker.Views"
    xmlns:viewModels="using:TimeTracker.ViewModels"
    xmlns:models="using:TimeTracker.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.DataContext>
        <viewModels:ApplicationsViewModel />
    </Page.DataContext>
    
    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
             Background="White"
             Padding="40,20"
             BorderBrush="#E5E5E5"
             BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding HeaderTitle}"
                            Style="{StaticResource PageHeaderTextStyle}"/>
                    <TextBlock Text="{Binding HeaderSubtitle}"
                            Margin="0,6,0,0"
                            Style="{StaticResource CaptionTextStyle}" />
                </StackPanel>

                <!-- Кнопка сохранить -->
                <Button Grid.Column="1"
                        Content="Сохранить"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>

            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="40" Spacing="20">

                <!-- TABLE CARD -->
                <Border Background="White"
                        CornerRadius="16"
                        Padding="24"
                        BorderBrush="#E5E5E5"
                        BorderThickness="1">

                    <StackPanel Spacing="16">

                        <!-- HEADER -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Приложение"
                                       Style="{StaticResource MetricMediumTextStyle}"
                                       Foreground="#6B7280"/>

                            <TextBlock Grid.Column="1"
                                       Text="Категория"
                                       Style="{StaticResource MetricMediumTextStyle}"
                                       Foreground="#6B7280"/>
                        </Grid>

                        <!-- LIST -->
                        <ListView ItemsSource="{Binding Applications}"
                                  SelectionMode="None"
                                  BorderThickness="0">

                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:ApplicationItemViewModel">

                                    <Grid Margin="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="200" />
                                        </Grid.ColumnDefinitions>

                                        <!-- ICON -->
                                        <Border Width="32"
                                                Height="32"
                                                CornerRadius="8"
                                                Background="#F3F4F6"
                                                Margin="0,0,10,0">

                                            <Image Source="{Binding IconPath}"
                                                   Width="20"
                                                   Height="20"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- NAME -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Name}"
                                                   Style="{StaticResource AppTextStyle}"
                                                   VerticalAlignment="Center"/>

                                        <!-- CATEGORY -->
                                        <ComboBox Grid.Column="2"
                                                  ItemsSource="{Binding DataContext.Categories, ElementName=RootPage}"
                                                  SelectedValue="{x:Bind CategoryId, Mode=TwoWay}"
                                                  SelectedValuePath="Id"
                                                  DisplayMemberPath="Name"
                                                  Style="{StaticResource PrimaryComboBoxStyle}"/>
                                    </Grid>

                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
