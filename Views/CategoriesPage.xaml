<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TimeTracker.Views.CategoriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:TimeTracker.ViewModels">

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="White"
                Padding="40,20"
                BorderBrush="#E5E5E5"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding HeaderTitle}"
                               Style="{StaticResource PageHeaderTextStyle}"/>
                    <TextBlock Text="{Binding HeaderSubtitle}"
                               Margin="0,6,0,0"
                               Style="{StaticResource CaptionTextStyle}" />
                </StackPanel>

                <!-- Period selector -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Content="Сегодня"
                            Padding="18,6"
                            Background="#111827"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="8" />
                    <Button Content="Неделя"
                            Padding="18,6"
                            Background="#F3F4F6"
                            Foreground="#4B5563"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8" />
                    <Button Content="Месяц"
                            Padding="18,6"
                            Background="#F3F4F6"
                            Foreground="#4B5563"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- SCROLLABLE CONTENT -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="40"
                        Spacing="30">

                <!-- TOP CATEGORY CARDS -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Work -->
                    <Border Grid.Column="0"
                            Background="White"
                            CornerRadius="16"
                            Padding="24"
                            BorderBrush="#E5E5E5"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding WorkSummary.Name}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#111827" />
                                <TextBlock Text="{Binding WorkSummary.TimeText}"
                                           FontSize="26"
                                           FontWeight="SemiBold"
                                           Foreground="#111827" />
                                <TextBlock Text="{Binding WorkSummary.DeltaText}"
                                           Style="{StaticResource PositiveDeltaTextStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Spacing="4">
                                <TextBlock Text="{Binding WorkSummary.PercentText}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="#2563EB"
                                           HorizontalAlignment="Right" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Entertainment -->
                    <Border Grid.Column="2"
                            Background="White"
                            CornerRadius="16"
                            Padding="24"
                            BorderBrush="#E5E5E5"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding EntertainmentSummary.Name}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#111827" />
                                <TextBlock Text="{Binding EntertainmentSummary.TimeText}"
                                           FontSize="26"
                                           FontWeight="SemiBold"
                                           Foreground="#111827" />
                                <TextBlock Text="{Binding EntertainmentSummary.DeltaText}"
                                           Style="{StaticResource NegativeDeltaTextStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Spacing="4">
                                <TextBlock Text="{Binding EntertainmentSummary.PercentText}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="#F97316"
                                           HorizontalAlignment="Right" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- APP LISTS -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Work apps -->
                    <Border Grid.Column="0"
                            Background="White"
                            CornerRadius="16"
                            Padding="24"
                            BorderBrush="#E5E5E5"
                            BorderThickness="1">
                        <StackPanel Spacing="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Приложение"
                                           Style="{StaticResource MetricMediumTextStyle}"
                                           Foreground="#6B7280" />

                                <TextBlock Grid.Column="1"
                                           Text="Время"
                                           Style="{StaticResource MetricMediumTextStyle}"
                                           Foreground="#6B7280"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding WorkApplications}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:CategoryApplicationUsage">
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="32" Height="32" Background="#A4C5EA" CornerRadius="8" Margin="0,0,10,0"/>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{x:Bind Name}"
                                                           Style="{StaticResource AppTextStyle}"/>
                                                <TextBlock Text="{x:Bind Category}"
                                                           Style="{StaticResource CaptionTextStyle}" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind TimeText}"
                                                       Style="{StaticResource AppTextStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Entertainment apps -->
                    <Border Grid.Column="2"
                            Background="White"
                            CornerRadius="16"
                            Padding="24"
                            BorderBrush="#E5E5E5"
                            BorderThickness="1">
                        <StackPanel Spacing="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Приложение"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#6B7280" />

                                <TextBlock Grid.Column="1"
                                           Text="Время"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#6B7280"
                                           HorizontalAlignment="Right"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding EntertainmentApplications}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:CategoryApplicationUsage">
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="32" Height="32" Background="#A4C5EA" CornerRadius="8" Margin="0,0,10,0"/>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{x:Bind Name}"
                                                           Style="{StaticResource AppTextStyle}" />
                                                <TextBlock Text="{x:Bind Category}"
                                                           Style="{StaticResource CaptionTextStyle}" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind TimeText}"
                                                       Style="{StaticResource AppTextStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- TIP -->
                <Border Background="White"
                        CornerRadius="16"
                        Padding="24"
                        BorderBrush="#E5E5E5"
                        BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding TipTitle}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#111827" />
                        <TextBlock Text="{Binding TipText}"
                                   FontSize="14"
                                   Foreground="#4B5563"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
