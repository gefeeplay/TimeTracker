<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TimeTracker.Views.CategoriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:TimeTracker.ViewModels">

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="White"
                Padding="40,20"
                BorderBrush="#E5E5E5"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding HeaderTitle}"
                               Style="{StaticResource PageHeaderTextStyle}"/>
                    <TextBlock Text="{Binding HeaderSubtitle}"
                               Margin="0,6,0,0"
                               Style="{StaticResource CaptionTextStyle}" />
                </StackPanel>

                <!-- Period selector -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8">

                    <Button Content="Сегодня"
                            Click="Today_Click"
                            Style="{x:Bind ViewModel.SelectedPeriod,
                                    Mode=OneWay,
                                    Converter={StaticResource PeriodToStyleConverter},
                                    ConverterParameter=0}" />   

                    <Button Content="Неделя"
                            Click="Week_Click"
                            Style="{x:Bind ViewModel.SelectedPeriod,
                                    Mode=OneWay,
                                    Converter={StaticResource PeriodToStyleConverter},
                                    ConverterParameter=1}" />

                    <Button Content="Месяц"
                            Click="Month_Click"
                            Style="{x:Bind ViewModel.SelectedPeriod,
                                        Mode=OneWay,
                                        Converter={StaticResource PeriodToStyleConverter},
                                        ConverterParameter=2}" />

                </StackPanel>
            </Grid>
        </Border>

        <!-- SCROLLABLE CONTENT -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20"
                        Spacing="15">

                <!-- TOP CATEGORY CARDS -->
                <ListView ItemsSource="{Binding Categories}"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          Background="Transparent"
                          BorderThickness="0"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          Padding="20">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"
                                           MaximumRowsOrColumns="3"
                                           ItemWidth="500"
                                           HorizontalAlignment="Stretch"
                                           MinHeight="250"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:CategoryBlock">

                            <Border Background="White"
                                    CornerRadius="16"
                                    Padding="24"
                                    Margin="0,0,30,30"
                                    BorderBrush="#E5E5E5"
                                    BorderThickness="1"
                                    MinHeight="500">

                                <StackPanel Spacing="20">

                                    <!-- SUMMARY -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding Summary.Name}"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"
                                                       Foreground="#111827" />

                                            <TextBlock Text="{Binding Summary.TimeText}"
                                                       FontSize="26"
                                                       FontWeight="SemiBold"
                                                       Foreground="#111827" />

                                            <TextBlock Text="{Binding Summary.DeltaText}"
                                                       Style="{Binding Summary.DeltaTextStyle}" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Summary.PercentText}"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="#2563EB"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- HEADER -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Приложение"
                                                   Style="{StaticResource MetricMediumTextStyle}"
                                                   Foreground="#6B7280" />

                                        <TextBlock Grid.Column="1"
                                                   Text="Время"
                                                   Style="{StaticResource MetricMediumTextStyle}"
                                                   Foreground="#6B7280"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- APPS -->
                                    <ItemsControl ItemsSource="{Binding TopApplications}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="viewModels:CategoryApplicationUsage">

                                                <Grid Margin="0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- ICON -->
                                                    <Border Grid.Column="0"
                                                            Width="32"
                                                            Height="32"
                                                            CornerRadius="8"
                                                            Margin="0,0,10,0"
                                                            Background="#F3F4F6">

                                                        <Image Source="{Binding IconPath}"
                                                               Width="20"
                                                               Height="20"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                    </Border>

                                                    <!-- TEXT -->
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{x:Bind Name}" Style="{StaticResource AppTextStyle}" />

                                                        <TextBlock Text="{x:Bind Category}" Style="{StaticResource CaptionTextStyle}" />
                                                    </StackPanel>

                                                    <!-- TIME -->
                                                    <TextBlock Grid.Column="2"
                                                               Text="{x:Bind TimeText}"
                                                               Style="{StaticResource AppTextStyle}"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>

                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        
                                    </ItemsControl>
                                    <TextBlock Text="{x:Bind GetFormattedText(RemainingCount), Mode=OneWay}"
                                               Visibility="{Binding RemainingCount, Converter={StaticResource ZeroToCollapsedConverter}}"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Margin="0,8,0,0"/>

                                </StackPanel>
                            </Border>

                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- TIP -->
                <Border Background="White"
                        CornerRadius="16"
                        Padding="24"
                        BorderBrush="#E5E5E5"
                        BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding TipTitle}"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <Grid ColumnDefinitions="Auto, *">
                            <Border Grid.Column="0"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="8"
                                    Margin="0,0,10,0"
                                    Background="#F3F4F6"
                                    VerticalAlignment="Top">
                                <FontIcon Glyph="&#xea1f;" FontSize="18" Foreground="#548AC5"/>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding TipText}"
                                       FontSize="14"
                                       Foreground="#4B5563"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
