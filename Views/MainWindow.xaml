<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TimeTracker.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:TimeTracker.Views"
    Title="TimeTracker">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= LEFT NAVBAR ================= -->

        <Grid Grid.Column="0"
          Background="White"
          BorderBrush="#E5E5E5"
          BorderThickness="0,0,1,0">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo -->
            <StackPanel Grid.Row="0"
                    Margin="40,30,20,40"
                    Orientation="Horizontal" Spacing="8">

                <Image Source="/Assets/logo.svg"
                   Width="32"
                   Height="32"/>

                <TextBlock Text="ScreenTime"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#636E72"/>
            </StackPanel>

            <!-- Navigation -->
            <StackPanel Grid.Row="1"
                    Margin="20,0"
                    Spacing="20">

                <Button
                Command="{Binding NavigateCommand}"
                CommandParameter="DashboardPage"
                Style="{Binding CurrentPage,
                        Converter={StaticResource PageToStyleConverter},
                        ConverterParameter=DashboardPage}">

                    <StackPanel Orientation="Horizontal" Spacing="8">

                        <FontIcon Glyph="&#xea8a;" FontSize="18"/>

                        <TextBlock Text="Главная"/>

                    </StackPanel>
                </Button>

                <Button Command="{Binding NavigateCommand}"
                    CommandParameter="CategoriesPage"
                    Style="{Binding CurrentPage,
                            Converter={StaticResource PageToStyleConverter},
                            ConverterParameter=CategoriesPage}">
                    <StackPanel Orientation="Horizontal" Spacing="10">

                        <FontIcon Glyph="&#xf0e2;" FontSize="18"/>

                        <TextBlock Text="Категории"/>
                    </StackPanel>
                </Button>

                <Button Content="Отчёты"
                    FontSize="16"
                    Foreground="#636E72"/>

            </StackPanel>

            <!-- Bottom -->
            <StackPanel Grid.Row="2"
                    Margin="20,0,20,30">
                <Button Command="{Binding NavigateCommand}"
                    CommandParameter="SettingsPage"
                    Style="{Binding CurrentPage,
                            Converter={StaticResource PageToStyleConverter},
                            ConverterParameter=SettingsPage}">

                    <StackPanel Orientation="Horizontal" Spacing="10">

                        <FontIcon Glyph="&#xf8b0;" FontSize="18"/>

                        <TextBlock Text="Настройки"/>
                    </StackPanel>
                </Button>
            </StackPanel>

        </Grid>

        <!-- ================= CONTENT HOST ================= -->

        <Frame Grid.Column="1"
           x:Name="ContentFrame"/>

    </Grid>
</Window>
